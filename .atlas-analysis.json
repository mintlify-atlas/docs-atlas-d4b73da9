  "keyFeatures": [
    "Real-time file system change monitoring using OS-native events (inotify, FSEvents, kqueue)",
    "Flexible query system with generators (since, suffix, glob, path, all) and expression filters",
    "Persistent subscriptions that push file change notifications to connected clients",
    "Trigger system to execute commands automatically when matching files change",
    "Source control aware queries that minimize noise during large rebases or merges",
    "Multi-language client libraries (Node.js, Python, C++, Java, Ruby, Rust)",
    "JSON/BSER socket protocol for efficient IPC communication",
    "Named cursors and clock IDs for race-free incremental file change tracking"
  ],
  "publicApiSurface": [
    "watchman watch-project <path>",
    "watchman watch <path>",
    "watchman query <path> <query-object>",
    "watchman since <path> <clockspec> [patterns]",
    "watchman find <path> [patterns]",
    "watchman subscribe <path> <name> <query>",
    "watchman unsubscribe <path> <name>",
    "watchman trigger <path> <name> [patterns] -- <command>",
    "watchman trigger-list <path>",
    "watchman trigger-del <path> <name>",
    "watchman clock <path>",
    "watchman version",
    "watchman get-sockname",
    "watchman shutdown-server",
    "watchman state-enter <path> <name>",
    "watchman state-leave <path> <name>",
    "npm package: fb-watchman",
    "PyPI package: pywatchman",
    "C++ client: watchman/WatchmanClient.h"
  ]
